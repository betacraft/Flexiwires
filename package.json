{
  "name": "flexiwires",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "FlexiWires — premium product website",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "sync": "astro sync",
    "typecheck": "astro check",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "ci": "pnpm typecheck && pnpm check",
    "prepare": "husky",
    "clean": "rm -rf dist .astro node_modules/.vite"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.5.5",
    "@astrojs/netlify": "^7.0.10",
    "@astrojs/partytown": "^2.1.7",
    "@astrojs/react": "^5.0.5",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^10.0.7",
    "@lucide/astro": "^1.17.0",
    "@sanity/client": "^7.22.1",
    "@sanity/image-url": "^2.1.1",
    "astro": "^6.3.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.4.16",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,astro,json,jsonc,css,md,mdx}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
