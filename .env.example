# Copy to .env (or .env.local) and fill in values.
# All `astro:env` schema is the single source of truth — see astro.config.ts.

# --- Deployment ---
# Which adapter astro.config.ts picks at build time. Values: vercel | cloudflare | netlify | none
DEPLOY_TARGET=vercel

# --- Public (exposed to the client) ---
SITE_URL=https://flexiwires.com
PUBLIC_ANALYTICS_PROVIDER=none          # none | plausible | vercel | ga4 | posthog
PUBLIC_ANALYTICS_DOMAIN=flexiwires.com

# --- Sanity (server-only) ---
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2026-01-01
SANITY_READ_TOKEN=                       # leave blank to use the CDN with published-only content
