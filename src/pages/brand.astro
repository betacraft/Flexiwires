---
// FlexiWires — Brand Guidelines & Design System
// Single self-contained page (client-shareable). Tokens mirror the live
// My Theme landing page in src/styles/landing.css.
const updated = 'June 2026';

const colors = {
  brand: [
    { name: 'Signature Green', hex: '#3FE864', token: '--accent', use: 'Primary actions, highlights, status dots' },
    { name: 'Green Hover', hex: '#2BD650', token: 'accent-hover', use: 'CTA hover state' },
    { name: 'Ink', hex: '#0A0A0A', token: '--foreground', use: 'Primary text, accent-foreground on green' },
    { name: 'Hero Black', hex: '#111214', token: '--mytheme-hero-bg', use: 'Dark panels (hero, rail, app-CTA)' },
  ],
  neutrals: [
    { name: 'Cream', hex: '#FAF8F4', token: '--background', use: 'Page background' },
    { name: 'Surface', hex: '#F5F3EF', token: '--surface-2', use: 'Tinted bands / cards' },
    { name: 'White', hex: '#FFFFFF', token: '--surface-1', use: 'Cards on cream' },
    { name: 'Border', hex: '#E8E4DC', token: '--border', use: 'Dividers, outlines' },
    { name: 'Muted', hex: '#6B6B6B', token: '--muted-foreground', use: 'Secondary text, eyebrows' },
  ],
  mint: [
    { name: 'Mint 1', hex: '#EAF7EE', token: '—', use: 'App-CTA panel gradient (top)' },
    { name: 'Mint 2', hex: '#DFF3E6', token: '—', use: 'App-CTA panel gradient (bottom)' },
  ],
};

const type = [
  { role: 'Display / Accent', font: 'Instrument Serif', italic: true, sample: 'all from your phone', note: 'Italic serif for expressive accent lines inside headings.' },
  { role: 'Headings & UI', font: 'Inter', italic: false, sample: 'Compare rails, lock the rate', note: 'Weights 300–700. Tight tracking on large sizes.' },
  { role: 'Mono / Data', font: 'JetBrains Mono', italic: false, sample: 'USD → MXN · 17.4521', note: 'Eyebrows, figures, corridor labels. Uppercase + wide tracking for labels.' },
];

const scale = [
  { name: 'Hero H1', size: 'clamp(2.5rem, 5vw, 4rem)', font: 'Inter 600 / Instrument Serif italic' },
  { name: 'Section H2', size: 'clamp(36px, 4vw, 56px)', font: 'Instrument Serif / Inter' },
  { name: 'Lede', size: '17px', font: 'Inter 400' },
  { name: 'Body', size: '16px', font: 'Inter 400' },
  { name: 'Eyebrow', size: '11px · 0.18em tracking · uppercase', font: 'JetBrains Mono' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>FlexiWires — Brand Guidelines & Design System</title>
    <meta name="description" content="The FlexiWires brand guideline and design system: logo, color, type, components and interaction patterns." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <style>
      :root {
        --green: #3fe864; --green-hover: #2bd650;
        --ink: #0a0a0a; --black: #111214;
        --cream: #faf8f4; --surface: #f5f3ef; --white: #fff;
        --border: #e8e4dc; --muted: #6b6b6b;
        --sans: 'Inter', system-ui, sans-serif;
        --serif: 'Instrument Serif', Georgia, serif;
        --mono: 'JetBrains Mono', ui-monospace, monospace;
        --radius: 20px; --gutter: 20px;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: var(--sans); background: var(--cream); color: var(--ink); -webkit-font-smoothing: antialiased; line-height: 1.5; }
      .wrap { max-width: 1080px; margin: 0 auto; padding: 0 24px; }
      a { color: inherit; }

      /* header */
      .bg-hero { background: var(--black); color: #fff; border-radius: 0 0 var(--radius) var(--radius); padding: 64px 0 56px; }
      .brandmark { display: inline-flex; align-items: center; gap: 10px; margin-bottom: 40px; }
      .brandmark img { height: 34px; }
      .bg-hero h1 { font-family: var(--sans); font-weight: 600; font-size: clamp(2.2rem, 5vw, 3.4rem); letter-spacing: -0.03em; line-height: 1.05; }
      .bg-hero h1 em { font-family: var(--serif); font-style: italic; color: var(--green); }
      .bg-hero p { color: rgba(255,255,255,0.6); margin-top: 16px; max-width: 56ch; font-size: 17px; }
      .meta { margin-top: 28px; font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.45); }

      /* section scaffold */
      section { padding: 64px 0; border-bottom: 1px solid var(--border); }
      .eyebrow { font-family: var(--mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); margin-bottom: 14px; }
      h2 { font-family: var(--serif); font-size: clamp(28px, 4vw, 44px); letter-spacing: -0.01em; line-height: 1.1; margin-bottom: 8px; }
      .lede { color: var(--muted); max-width: 60ch; margin-bottom: 36px; font-size: 16px; }

      /* color grid */
      .swatches { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; }
      .swatch { border: 1px solid var(--border); border-radius: 14px; overflow: hidden; background: var(--white); }
      .swatch__chip { height: 96px; }
      .swatch__body { padding: 14px 16px; }
      .swatch__name { font-weight: 600; font-size: 14px; }
      .swatch__hex { font-family: var(--mono); font-size: 12px; color: var(--ink); margin-top: 4px; text-transform: uppercase; }
      .swatch__use { font-size: 12px; color: var(--muted); margin-top: 8px; line-height: 1.45; }
      .group-title { font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); margin: 28px 0 14px; }

      /* type */
      .type-row { display: grid; grid-template-columns: 200px 1fr; gap: 24px; padding: 24px 0; border-top: 1px solid var(--border); align-items: baseline; }
      .type-row:first-child { border-top: 0; }
      .type-meta .role { font-weight: 600; font-size: 14px; }
      .type-meta .fam { font-family: var(--mono); font-size: 12px; color: var(--muted); margin-top: 4px; }
      .type-meta .note { font-size: 12px; color: var(--muted); margin-top: 10px; line-height: 1.5; }
      .type-sample { font-size: clamp(28px, 4vw, 44px); line-height: 1.1; letter-spacing: -0.01em; }
      .type-sample.serif { font-family: var(--serif); font-style: italic; }
      .type-sample.mono { font-family: var(--mono); font-size: clamp(20px, 3vw, 30px); letter-spacing: 0; }

      table.scale { width: 100%; border-collapse: collapse; font-size: 14px; }
      table.scale td, table.scale th { text-align: left; padding: 12px 8px; border-bottom: 1px solid var(--border); }
      table.scale th { font-family: var(--mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); font-weight: 500; }
      table.scale td:nth-child(2) { font-family: var(--mono); font-size: 12px; }

      /* logo */
      .logo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
      .logo-box { border: 1px solid var(--border); border-radius: 14px; height: 160px; display: flex; align-items: center; justify-content: center; }
      .logo-box img { height: 44px; }
      .logo-box.on-dark { background: var(--black); }
      .logo-box.on-cream { background: var(--cream); }
      .logo-cap { font-size: 12px; color: var(--muted); margin-top: 8px; font-family: var(--mono); letter-spacing: 0.06em; }

      /* components */
      .btn { display: inline-flex; align-items: center; gap: 8px; font-family: var(--sans); font-weight: 600; font-size: 14px; padding: 13px 22px; border-radius: 999px; border: 0; cursor: pointer; }
      .btn--primary { background: var(--green); color: var(--ink); }
      .btn--primary:hover { background: var(--green-hover); }
      .btn--ghost { background: transparent; color: var(--ink); border: 1px solid var(--border); }
      .comp-row { display: flex; flex-wrap: wrap; gap: 16px; align-items: center; margin-bottom: 28px; }
      .chip { display: inline-flex; align-items: center; gap: 8px; font-family: var(--mono); font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; padding: 10px 18px; border-radius: 999px; }
      .chip--light { background: var(--white); border: 1px solid var(--border); color: var(--ink); }
      .chip--dark { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.14); color: #fff; }
      .chip .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green); }
      .dark-card { background: var(--black); border-radius: var(--radius); padding: 28px; }
      .card { background: var(--white); border: 1px solid var(--border); border-radius: 18px; padding: 22px; }
      .principles { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; }
      .principles h3 { font-size: 16px; margin-bottom: 6px; }
      .principles p { font-size: 13px; color: var(--muted); line-height: 1.5; }
      .radii { display: flex; gap: 20px; flex-wrap: wrap; }
      .radii .r { width: 100px; height: 100px; background: var(--black); }
      .radii .cap { font-family: var(--mono); font-size: 11px; color: var(--muted); margin-top: 8px; }

      /* design system divider banner */
      .ds-banner { background: var(--black); color: #fff; padding: 56px 0; border-bottom: 1px solid var(--border); }
      .ds-banner .eyebrow { color: rgba(255,255,255,0.5); }
      .ds-banner h2 { font-family: var(--serif); color: #fff; }
      .ds-banner h2 em { font-style: italic; color: var(--green); }
      .ds-banner p { color: rgba(255,255,255,0.6); max-width: 60ch; margin-top: 10px; }

      /* rationale rows */
      .rationale { display: grid; grid-template-columns: 220px 1fr; gap: 28px; padding: 28px 0; border-top: 1px solid var(--border); }
      .rationale:first-of-type { border-top: 0; }
      .rationale__k { font-weight: 600; font-size: 15px; }
      .rationale__k .sub { display: block; font-family: var(--mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); margin-top: 6px; font-weight: 400; }
      .rationale__v p { font-size: 14.5px; line-height: 1.6; color: #333; margin-bottom: 10px; }
      .rationale__v p:last-child { margin-bottom: 0; }
      .rationale__v strong { color: var(--ink); font-weight: 600; }
      .why { list-style: none; margin-top: 6px; }
      .why li { position: relative; padding-left: 22px; font-size: 14px; color: #333; line-height: 1.55; margin-bottom: 8px; }
      .why li::before { content: '✓'; position: absolute; left: 0; color: var(--green); font-weight: 700; }
      .tag { display: inline-block; font-family: var(--mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); border: 1px solid var(--border); border-radius: 999px; padding: 4px 10px; margin: 0 6px 6px 0; }

      .icon-row { display: flex; gap: 16px; flex-wrap: wrap; margin: 16px 0 6px; }
      .icon-demo { width: 56px; height: 56px; border: 1px solid var(--border); border-radius: 14px; display: flex; align-items: center; justify-content: center; background: var(--white); }
      .icon-demo svg { width: 24px; height: 24px; fill: none; stroke: var(--ink); stroke-width: 1.75; stroke-linecap: round; stroke-linejoin: round; }
      .do-dont { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 10px; }
      .dd { border: 1px solid var(--border); border-radius: 14px; padding: 16px 18px; font-size: 13.5px; line-height: 1.55; }
      .dd h4 { font-size: 12px; font-family: var(--mono); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 10px; }
      .dd--do h4 { color: #15803d; }
      .dd--dont h4 { color: #b91c1c; }
      .dd ul { list-style: none; } .dd li { margin-bottom: 6px; color: #444; }

      footer { padding: 40px 0 80px; color: var(--muted); font-size: 13px; }
      footer a { color: var(--ink); }

      @media (max-width: 720px) {
        .rationale { grid-template-columns: 1fr; gap: 10px; }
        .do-dont { grid-template-columns: 1fr; }
      }

      @media (max-width: 720px) {
        .type-row { grid-template-columns: 1fr; gap: 10px; }
        .logo-grid { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body data-theme="mytheme">
    <header class="bg-hero">
      <div class="wrap">
        <span class="brandmark"><img src="./assets/Flexi-light.svg" alt="FlexiWires" /></span>
        <h1>Brand Guidelines &amp; <em>Design System</em></h1>
        <p>The visual language behind FlexiWires — cross-border money, routed. Use this as the single source of truth for color, type, logo and components across product and marketing.</p>
        <div class="meta">FlexiWires · v1.0 · Updated {updated}</div>
      </div>
    </header>

    <!-- Brand essence -->
    <section>
      <div class="wrap">
        <div class="eyebrow">Brand essence</div>
        <h2>Precise, fast, premium.</h2>
        <p class="lede">FlexiWires compares every cross-border wire rail on one screen. The brand is engineered and calm with one decisive accent — a signature green that marks the moment of action.</p>
        <div class="principles">
          <div class="card"><h3>Engineered</h3><p>Monospace data, exact figures, clean grids. It should feel like a tool built by people who move money.</p></div>
          <div class="card"><h3>Calm</h3><p>Generous space, muted neutrals, a cream canvas. Green is rationed so it always means something.</p></div>
          <div class="card"><h3>Expressive</h3><p>An italic serif accent line cuts through the sans headings — a human note in an engineered system.</p></div>
        </div>
      </div>
    </section>

    <!-- Logo -->
    <section>
      <div class="wrap">
        <div class="eyebrow">Logo</div>
        <h2>The wordmark</h2>
        <p class="lede">The flexi wordmark with its green glyph. Use the light wordmark on dark surfaces and the dark wordmark on cream/white. Keep clear space of at least the glyph height around it; never recolor the wordmark outside these two variants.</p>
        <div class="logo-grid">
          <div>
            <div class="logo-box on-dark"><img src="./assets/Flexi-light.svg" alt="FlexiWires light logo" /></div>
            <div class="logo-cap">Light · on dark (#111214)</div>
          </div>
          <div>
            <div class="logo-box on-cream"><img src="./assets/Flexi.svg" alt="FlexiWires dark logo" /></div>
            <div class="logo-cap">Dark · on cream / white</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Color -->
    <section>
      <div class="wrap">
        <div class="eyebrow">Color</div>
        <h2>Color system</h2>
        <p class="lede">A cream canvas, near-black ink, and one signature green. Dark panels (#111214) anchor the hero, the corridor rail and the app section.</p>

        <div class="group-title">Brand</div>
        <div class="swatches">
          {colors.brand.map((c) => (
            <div class="swatch">
              <div class="swatch__chip" style={`background:${c.hex}`}></div>
              <div class="swatch__body">
                <div class="swatch__name">{c.name}</div>
                <div class="swatch__hex">{c.hex}</div>
                <div class="swatch__use">{c.use}</div>
              </div>
            </div>
          ))}
        </div>

        <div class="group-title">Neutrals</div>
        <div class="swatches">
          {colors.neutrals.map((c) => (
            <div class="swatch">
              <div class="swatch__chip" style={`background:${c.hex}; ${c.hex === '#FFFFFF' || c.hex === '#FAF8F4' || c.hex === '#F5F3EF' || c.hex === '#E8E4DC' ? 'box-shadow: inset 0 0 0 1px #e8e4dc;' : ''}`}></div>
              <div class="swatch__body">
                <div class="swatch__name">{c.name}</div>
                <div class="swatch__hex">{c.hex}</div>
                <div class="swatch__use">{c.use}</div>
              </div>
            </div>
          ))}
        </div>

        <div class="group-title">Mint (app-CTA panel)</div>
        <div class="swatches">
          {colors.mint.map((c) => (
            <div class="swatch">
              <div class="swatch__chip" style={`background:${c.hex}; box-shadow: inset 0 0 0 1px #e8e4dc;`}></div>
              <div class="swatch__body">
                <div class="swatch__name">{c.name}</div>
                <div class="swatch__hex">{c.hex}</div>
                <div class="swatch__use">{c.use}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Type -->
    <section>
      <div class="wrap">
        <div class="eyebrow">Typography</div>
        <h2>Three typefaces</h2>
        <p class="lede">Inter carries the UI and headings, Instrument Serif (italic) provides the expressive accent, and JetBrains Mono handles labels and figures.</p>
        {type.map((t) => (
          <div class="type-row">
            <div class="type-meta">
              <div class="role">{t.role}</div>
              <div class="fam">{t.font}</div>
              <div class="note">{t.note}</div>
            </div>
            <div class={`type-sample ${t.font === 'Instrument Serif' ? 'serif' : ''} ${t.font === 'JetBrains Mono' ? 'mono' : ''}`}>{t.sample}</div>
          </div>
        ))}

        <div class="group-title">Type scale</div>
        <table class="scale">
          <thead><tr><th>Role</th><th>Size</th><th>Font</th></tr></thead>
          <tbody>
            {scale.map((s) => (<tr><td>{s.name}</td><td>{s.size}</td><td>{s.font}</td></tr>))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Components -->
    <section>
      <div class="wrap">
        <div class="eyebrow">Components</div>
        <h2>Core UI</h2>
        <p class="lede">Pill buttons, corridor chips and dark panels. Buttons use the signature green; on hover the label and arrow do a subtle 3D roll.</p>

        <div class="group-title">Buttons</div>
        <div class="comp-row">
          <button class="btn btn--primary">Get the app <span aria-hidden="true">↗</span></button>
          <button class="btn btn--primary">Start a transfer <span aria-hidden="true">→</span></button>
          <button class="btn btn--ghost">Secondary</button>
        </div>

        <div class="group-title">Corridor chips</div>
        <div class="comp-row">
          <span class="chip chip--light"><span class="dot"></span>USD → MXN</span>
          <span class="chip chip--light"><span class="dot"></span>USD → BRL</span>
        </div>
        <div class="dark-card comp-row" style="margin-bottom:0;">
          <span class="chip chip--dark"><span class="dot"></span>USD → COP</span>
          <span class="chip chip--dark"><span class="dot"></span>EUR → MXN</span>
          <span class="chip chip--dark"><span class="dot"></span>GBP → BRL</span>
        </div>
      </div>
    </section>

    <!-- Shape & motion -->
    <section>
      <div class="wrap">
        <div class="eyebrow">Shape &amp; motion</div>
        <h2>Radius, spacing &amp; interaction</h2>
        <p class="lede">Large soft radii on panels (32px) and pills (999px). Sections breathe with generous vertical rhythm. Motion is restrained: continuous corridor rail, 3D button text-roll, and gentle reveal-on-scroll.</p>
        <div class="radii">
          <div><div class="r" style="border-radius:32px"></div><div class="cap">Panels · 32px</div></div>
          <div><div class="r" style="border-radius:18px"></div><div class="cap">Cards · 18px</div></div>
          <div><div class="r" style="border-radius:999px"></div><div class="cap">Pills · 999px</div></div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         DESIGN SYSTEM · the reasoning behind every decision
         ============================================================ -->
    <div class="ds-banner">
      <div class="wrap">
        <div class="eyebrow">Design system</div>
        <h2>The reasoning, <em>not just the rules</em></h2>
        <p>Every choice below is tied back to one goal: make a cross-border money tool feel precise, fast and trustworthy. Here is what we picked, why we picked it, and how it supports the FlexiWires product.</p>
      </div>
    </div>

    <!-- Typography rationale -->
    <section>
      <div class="wrap">
        <div class="eyebrow">Typography · rationale</div>
        <h2>Why these three typefaces</h2>
        <p class="lede">A treasury product lives on numbers, scanning and trust. The type system is built around that: a neutral workhorse, a precise data face, and one expressive accent so it never feels cold.</p>

        <div class="rationale">
          <div class="rationale__k">Inter<span class="sub">UI &amp; Headings · Sans</span></div>
          <div class="rationale__v">
            <p>Inter is a screen-first neutral sans with a tall x-height and excellent legibility at small sizes — designed specifically for interfaces.</p>
            <ul class="why">
              <li><strong>Why:</strong> a fintech dashboard is read fast and often; Inter stays clear from 12px labels to 64px hero headlines.</li>
              <li><strong>Supports the product:</strong> the same face works in marketing and in-app, so the landing page and the real product feel like one thing.</li>
              <li><strong>Validation:</strong> proven at interface scale by Stripe-era fintech, GitHub, Figma; huge weight range (300–700) covers every hierarchy need.</li>
            </ul>
            <span class="tag">Weights 300–700</span><span class="tag">Tight tracking ≥ 32px</span><span class="tag">x-height: tall</span>
          </div>
        </div>

        <div class="rationale">
          <div class="rationale__k">Instrument Serif<span class="sub">Accent · Italic serif</span></div>
          <div class="rationale__v">
            <p>A high-contrast italic serif used only for the accent line inside a heading — e.g. <em style="font-family:var(--serif);font-style:italic">“all from your phone.”</em></p>
            <ul class="why">
              <li><strong>Why:</strong> pure sans reads efficient but impersonal. One italic serif line adds a human, editorial, premium note — the “routed.” / “your phone” moments.</li>
              <li><strong>Supports the product:</strong> money is emotional; the serif signals craft and confidence, separating FlexiWires from generic SaaS templates.</li>
              <li><strong>Validation:</strong> the sans-for-structure + serif-for-emotion pairing is a current premium-brand pattern; used sparingly it adds character without hurting legibility.</li>
            </ul>
            <span class="tag">Italic only</span><span class="tag">Accent lines &amp; emphasis</span><span class="tag">Never for body</span>
          </div>
        </div>

        <div class="rationale">
          <div class="rationale__k">JetBrains Mono<span class="sub">Data &amp; Labels · Mono</span></div>
          <div class="rationale__v">
            <p>A monospace face for figures, rates, corridor labels and eyebrows — anything that is data or a system label.</p>
            <ul class="why">
              <li><strong>Why:</strong> monospace makes numbers line up and read as “real data,” and tabular figures keep rates like <span style="font-family:var(--mono)">17.4521</span> stable as they update.</li>
              <li><strong>Supports the product:</strong> FX is all about comparing numbers; mono visually says “engineered, exact, machine-accurate.”</li>
              <li><strong>Validation:</strong> mono-for-data is the convention across trading, dev and fintech tools; wide-tracked uppercase mono is an instantly-readable label style.</li>
            </ul>
            <span class="tag">Tabular nums</span><span class="tag">Eyebrows · uppercase 0.18em</span><span class="tag">Rates &amp; corridors</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Color rationale -->
    <section>
      <div class="wrap">
        <div class="eyebrow">Color · rationale</div>
        <h2>Why this palette</h2>
        <p class="lede">A restrained, premium base with a single decisive accent — so color always carries meaning instead of decoration.</p>

        <div class="rationale">
          <div class="rationale__k">Signature Green<span class="sub">#3FE864 · Accent</span></div>
          <div class="rationale__v">
            <p>One bright, optimistic green reserved for action and confirmation.</p>
            <ul class="why">
              <li><strong>Why:</strong> green reads as “go / success / money saved” — exactly the feeling at the moment of sending. Rationing it to CTAs, status dots and the live indicator makes every green pixel meaningful.</li>
              <li><strong>Supports the product:</strong> users instantly learn “green = the next step / a positive outcome,” which speeds the core flow (quote → lock → send).</li>
              <li><strong>Validation:</strong> against the near-black ink and cream the green hits a strong, lively contrast while pairing with black text on the button for AA legibility.</li>
            </ul>
          </div>
        </div>

        <div class="rationale">
          <div class="rationale__k">Cream + Ink<span class="sub">#FAF8F4 / #0A0A0A</span></div>
          <div class="rationale__v">
            <p>Warm off-white canvas with near-black text instead of pure white/black.</p>
            <ul class="why">
              <li><strong>Why:</strong> cream feels premium and editorial (less clinical than #FFF); near-black softens harsh pure-black contrast for comfortable long reading.</li>
              <li><strong>Supports the product:</strong> a calm canvas lets the data and the single green accent stand out — critical when the screen is full of rates and numbers.</li>
            </ul>
          </div>
        </div>

        <div class="rationale">
          <div class="rationale__k">Hero Black<span class="sub">#111214 · Dark panels</span></div>
          <div class="rationale__v">
            <p>A soft near-black for the hero card, the corridor rail and the app section.</p>
            <ul class="why">
              <li><strong>Why:</strong> dark inset panels create rhythm and focus, framing the product shots and making the green pop hardest where it matters.</li>
              <li><strong>Supports the product:</strong> alternating cream and dark sections guide the eye down the page and spotlight key moments (hero, live corridors, get-the-app).</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Iconography -->
    <section>
      <div class="wrap">
        <div class="eyebrow">Iconography</div>
        <h2>Line icons, one weight</h2>
        <p class="lede">Icons are thin, geometric line icons (Lucide family) — never filled, never multi-color.</p>
        <div class="rationale">
          <div class="rationale__k">Style<span class="sub">Outline · 1.75 stroke</span></div>
          <div class="rationale__v">
            <div class="icon-row">
              <span class="icon-demo"><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg></span>
              <span class="icon-demo"><svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></span>
              <span class="icon-demo"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
              <span class="icon-demo"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg></span>
            </div>
            <ul class="why">
              <li><strong>Why:</strong> outline icons match the engineered, lightweight feel of the type and keep the UI calm; a single 1.75px stroke reads consistent at every size.</li>
              <li><strong>Supports the product:</strong> a clean, neutral icon set scales across product features (rails, compliance, alerts) without visual noise competing with the data.</li>
              <li><strong>Validation:</strong> Lucide is open-source, exhaustive and pixel-consistent — safe to grow the product on without redrawing icons.</li>
            </ul>
            <span class="tag">No fills</span><span class="tag">currentColor</span><span class="tag">Accent green only for status/checks</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Imagery -->
    <section>
      <div class="wrap">
        <div class="eyebrow">Imagery</div>
        <h2>Real product, real hands</h2>
        <p class="lede">Imagery is the actual app on real devices in real hands — not abstract illustration or stock office photos.</p>
        <div class="rationale">
          <div class="rationale__k">Direction<span class="sub">Product-led photography</span></div>
          <div class="rationale__v">
            <ul class="why">
              <li><strong>Why:</strong> showing the real FlexiWires screen on a phone proves the product exists and works — trust is everything when you handle people’s money.</li>
              <li><strong>Supports the product:</strong> hero (phone on a stone pedestal) and the app section (phone in hand) both put the live interface front-and-center, so visitors see exactly what they’ll use.</li>
              <li><strong>Treatment:</strong> clean cut-outs, soft drop-shadows, neutral/mint or dark backdrops; the device screen carries the only dense color (the app UI).</li>
            </ul>
            <div class="do-dont">
              <div class="dd dd--do">
                <h4>Do</h4>
                <ul>
                  <li>Use real app screens</li>
                  <li>Keep backgrounds calm (cream, mint, dark)</li>
                  <li>Soft realistic shadows</li>
                  <li>One focal device per panel</li>
                </ul>
              </div>
              <div class="dd dd--dont">
                <h4>Don't</h4>
                <ul>
                  <li>Generic stock “business people”</li>
                  <li>Busy or colorful backdrops</li>
                  <li>Hard cut-outs with no shadow</li>
                  <li>Recolor or distort the app UI</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Motion & layout principles -->
    <section>
      <div class="wrap">
        <div class="eyebrow">Motion &amp; layout · rationale</div>
        <h2>Restrained, purposeful motion</h2>
        <div class="rationale">
          <div class="rationale__k">Principles<span class="sub">Why it moves</span></div>
          <div class="rationale__v">
            <ul class="why">
              <li><strong>Continuous corridor rail:</strong> a always-moving marquee of live corridors signals an active, real-time network — reinforcing “12 partner rails, live.”</li>
              <li><strong>3D button text-roll:</strong> a small premium flourish on CTAs that rewards interaction without distracting from the task.</li>
              <li><strong>Reveal-on-scroll:</strong> gentle fade/translate as sections enter — guides attention and adds polish; respects <span style="font-family:var(--mono)">prefers-reduced-motion</span>.</li>
              <li><strong>Generous radius &amp; spacing:</strong> 32px panels and roomy vertical rhythm make a data-dense product feel calm and premium, not cramped.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <footer>
      <div class="wrap">
        FlexiWires Brand Guidelines &amp; Design System · v1.0 · {updated} &nbsp;·&nbsp; <a href="./">View the live landing page →</a>
      </div>
    </footer>
  </body>
