---
import Container from '@/components/ui/Container.astro';
import { FOOTER_NAV } from '@/consts/navigation';
import { SITE } from '@/consts/site';

const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-border py-12">
  <Container as="div" class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
    <div>
      <p class="text-sm font-semibold">{SITE.name}</p>
      <p class="mt-2 max-w-xs text-sm text-muted-foreground">{SITE.description}</p>
    </div>

    {
      FOOTER_NAV.length > 0 && (
        <nav aria-label="Footer" class="grid grid-cols-2 gap-8 md:grid-cols-3">
          {FOOTER_NAV.map((column) => (
            <div>
              <p class="text-xs font-medium uppercase tracking-wider text-muted-foreground">
                {column.heading}
              </p>
              <ul class="mt-3 space-y-2">
                {column.items.map((item) => (
                  <li>
                    <a class="text-sm hover:text-accent" href={item.href}>
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </nav>
      )
    }
  </Container>

  <Container as="div" class="mt-12 flex flex-col items-center justify-between gap-2 md:flex-row">
    <p class="text-xs text-muted-foreground">© {year} {SITE.name}. All rights reserved.</p>
  </Container>
</footer>
