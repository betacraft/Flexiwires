---
import Container from '@/components/ui/Container.astro';
import ThemeToggle from '@/components/ui/ThemeToggle.astro';
import { PRIMARY_NAV } from '@/consts/navigation';
import { SITE } from '@/consts/site';
---

<header class="sticky top-0 z-[var(--z-sticky)] border-b border-border bg-background/80 backdrop-blur">
  <Container as="div" class="flex h-14 items-center justify-between">
    <a href="/" class="text-sm font-semibold tracking-tight" aria-label={SITE.name}>
      {SITE.name}
    </a>

    {
      PRIMARY_NAV.length > 0 && (
        <nav aria-label="Primary" class="hidden md:block">
          <ul class="flex items-center gap-6 text-sm">
            {PRIMARY_NAV.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-muted-foreground transition-colors hover:text-foreground"
                  {...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }

    <div class="flex items-center gap-2">
      <ThemeToggle />
    </div>
  </Container>
</header>
