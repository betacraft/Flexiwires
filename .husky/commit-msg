#!/usr/bin/env sh
# Conventional Commits gate — accepts: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert
# Optional scope (lowercase letters/digits/hyphens) and optional ! for breaking change.

commit_msg=$(head -n1 "$1")
pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9-]+\))?!?: .{1,}'

if ! printf '%s' "$commit_msg" | grep -Eq "$pattern"; then
  printf '\n  Commit message does not follow Conventional Commits.\n' >&2
  printf '  Example: feat(landing): add hero animation\n\n' >&2
  exit 1
fi
